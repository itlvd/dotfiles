#!/usr/bin/env bash

lock="箚뙻  Lock"
suspend="箚쨪  Suspend"
logout="箚뛽  Logout"
reboot="箚몥  Reboot"
shutdown="箚맓  Shutdown"

chosen=$(printf '%s\n' "$lock" "$suspend" "$logout" "$reboot" "$shutdown" | \
    rofi -dmenu \
         -p "" \
         -no-custom \
         -theme ~/.config/rofi/themes/power-menu.rasi)

case "$chosen" in
    "$lock")     i3lock -c 000000 ;;
    "$suspend")  systemctl suspend ;;
    "$logout")   i3-msg exit ;;
    "$reboot")   systemctl reboot ;;
    "$shutdown") systemctl poweroff ;;
esac
